[Unit]
Description=AniDev Discord Bot Service
After=network.target

[Service]
Type=notify
ExecStart=/usr/local/bin/anicore
Restart=always
RestartSec=10
WatchdogSec=60

# Переменные окружения
Environment="DISCORD_TOKEN=your_discord_token_here"
EnvironmentFile=-/etc/anicore/env

# Безопасность
User=anicore
Group=anicore
PrivateTmp=yes
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/var/lib/anicore

# Логирование
StandardOutput=journal
StandardError=journal
SyslogIdentifier=anicore

# Ограничения ресурсов
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target

